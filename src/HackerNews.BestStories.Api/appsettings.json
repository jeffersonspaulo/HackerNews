{
  "HackerNews": {
    "BaseUrl": "https://hacker-news.firebaseio.com/v0/",
    "RequestTimeoutSeconds": 5
  },
  "BestStories": {
    "DefaultN": 10,
    "MaxN": 200,
    "MaxConcurrency": 10
  },
  "Cache": {
    "BestStoriesTtlSeconds": 60,
    "ItemTtlMinutes": 10
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}